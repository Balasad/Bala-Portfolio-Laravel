{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "variables": {
        "NODE_VERSION": "20",
        "NPM_CONFIG_PRODUCTION": "false"
      },
      "phases": {
        "build": {
          "cmds": [
            "composer install --no-dev --optimize-autoloader",
            "npm ci",
            "npm run build"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "php artisan serve --host=0.0.0.0 --port=${PORT}"
}
}